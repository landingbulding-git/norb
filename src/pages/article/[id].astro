---
import Layout from '@/src/layouts/Layout.astro';
import { ArrowLeft } from 'lucide-react';
import CodeBlock from '@/src/components/CodeBlock';

export async function getStaticPaths() {
  const NOTION_API_KEY = import.meta.env.NOTION_API_KEY || process.env.NOTION_API_KEY;
  const DATABASE_ID = import.meta.env.NOTION_DATABASE_ID || process.env.NOTION_DATABASE_ID;

  if (!NOTION_API_KEY || !DATABASE_ID) {
    return [];
  }

  const response = await fetch(`https://api.notion.com/v1/databases/${DATABASE_ID}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${NOTION_API_KEY}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      filter: {
        property: 'stage',
        select: {
          equals: 'live'
        }
      }
    })
  });

  const data = await response.json();
  
  if (!data.results) return [];

  return data.results.map((page: any) => {
    const titleProp = Object.values(page.properties).find((p: any) => p.type === 'title') as any;
    const title = titleProp?.title?.[0]?.plain_text || 'Untitled';

    const coverUrl = page.properties.cover?.url || null;

    const created = page.properties.created?.created_time || page.created_time;

    return {
      params: { id: page.id },
      props: { title, coverUrl, created }
    };
  });
}

const { id } = Astro.params;
const { title, coverUrl, created } = Astro.props;

const NOTION_API_KEY = import.meta.env.NOTION_API_KEY || process.env.NOTION_API_KEY;
let blocks: any[] = [];

try {
  const blocksRes = await fetch(`https://api.notion.com/v1/blocks/${id}/children?page_size=100`, {
    headers: {
      'Authorization': `Bearer ${NOTION_API_KEY}`,
      'Notion-Version': '2022-06-28'
    }
  });
  const blocksData = await blocksRes.json();
  if (blocksData.results) {
    blocks = blocksData.results;
  }
} catch (error) {
  console.error("Error fetching Notion blocks:", error);
}

// A simple block renderer
function renderRichText(richTextArray: any[]) {
  if (!richTextArray) return '';
  return richTextArray.map(rt => {
    let text = rt.plain_text;
    if (rt.annotations.bold) text = `<strong>${text}</strong>`;
    if (rt.annotations.italic) text = `<em>${text}</em>`;
    if (rt.annotations.strikethrough) text = `<del>${text}</del>`;
    if (rt.annotations.underline) text = `<u>${text}</u>`;
    if (rt.annotations.code) text = `<code class="bg-zinc-800 text-orange-400 px-1 py-0.5 rounded text-sm">${text}</code>`;
    if (rt.href) text = `<a href="${rt.href}" target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:underline">${text}</a>`;
    return text;
  }).join('');
}
---

<Layout title={`${title} | Norb.dev`}>
  <main class="max-w-3xl mx-auto px-6 py-12 md:py-20 relative z-10">
    <a href="/" class="inline-flex items-center gap-2 text-zinc-500 hover:text-orange-500 transition-colors mb-8 font-mono text-sm">
      <ArrowLeft class="w-4 h-4" />
      Back to Home
    </a>

    <article class="space-y-8">
      {coverUrl && (
        <div class="w-full h-64 md:h-96 rounded-2xl overflow-hidden border border-zinc-800 shadow-2xl">
          <img 
            src={coverUrl} 
            alt={title} 
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-full object-cover" 
          />
        </div>
      )}

      <div class="space-y-4">
        <h1 class="text-3xl md:text-5xl font-display font-bold text-zinc-100 leading-tight">
          {title}
        </h1>
        <div class="text-zinc-500 font-mono text-sm">
          Published on {new Date(created).toLocaleDateString()}
        </div>
      </div>

      <div class="prose prose-invert prose-orange max-w-none mt-10 space-y-6 text-zinc-300 leading-relaxed">
        {blocks.map(block => {
          if (block.type === 'paragraph') {
            return <p set:html={renderRichText(block.paragraph.rich_text)} />;
          }
          if (block.type === 'heading_1') {
            return <h1 class="text-2xl font-bold text-zinc-100 mt-10 mb-4" set:html={renderRichText(block.heading_1.rich_text)} />;
          }
          if (block.type === 'heading_2') {
            return <h2 class="text-xl font-bold text-zinc-100 mt-8 mb-3" set:html={renderRichText(block.heading_2.rich_text)} />;
          }
          if (block.type === 'heading_3') {
            return <h3 class="text-lg font-bold text-zinc-100 mt-6 mb-2" set:html={renderRichText(block.heading_3.rich_text)} />;
          }
          if (block.type === 'bulleted_list_item') {
            return <li class="ml-4 list-disc marker:text-orange-500" set:html={renderRichText(block.bulleted_list_item.rich_text)} />;
          }
          if (block.type === 'numbered_list_item') {
            return <li class="ml-4 list-decimal marker:text-zinc-500" set:html={renderRichText(block.numbered_list_item.rich_text)} />;
          }
          if (block.type === 'quote') {
            return <blockquote class="border-l-4 border-orange-500 pl-4 italic text-zinc-400 my-6" set:html={renderRichText(block.quote.rich_text)} />;
          }
          if (block.type === 'code') {
            return (
              <CodeBlock client:visible code={block.code.rich_text[0]?.plain_text || ''} />
            );
          }
          if (block.type === 'image') {
            const imageUrl = block.image.type === 'external' ? block.image.external.url : block.image.file.url;
            return <img src={imageUrl} alt="Article image" loading="lazy" decoding="async" class="rounded-xl border border-zinc-800 my-8 w-full shadow-lg" />;
          }
          // Fallback or ignored block types
          return null;
        })}
      </div>
    </article>
  </main>
</Layout>